# --- Discord Bot (optional) ---
# 1. Create a bot at https://discord.com/developers/applications
# 2. Enable "Message Content Intent" in Bot settings
# 3. Invite bot with scope: bot + applications.commands
# 4. Set these env vars on Railway:

DISCORD_TOKEN=your_bot_token_here
DISCORD_CHANNEL=your_channel_id_here
# Comma-separated Discord user IDs allowed to use slash commands:
DISCORD_ALLOWED_USERS=1521970827073949839
